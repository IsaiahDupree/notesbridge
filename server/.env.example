# NotesBridge server (Vercel) environment.
# Copy to .env.local for local dev, or set these in the Vercel project settings.

# --- Storage (Redis-shaped, backed by Supabase Postgres) ---
# The server talks to Supabase via PostgREST RPC (nb_get/nb_set/nb_lpush/...).
# Apply supabase/schema.sql to your project first, then set:
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth ---
# Signs all JWTs (session / agent / mcp tokens). Generate with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
